############ hp emy

function  conn_ionos  {

rclone mount ionos:   $HOME/mount/ionos --vfs-cache-mode full   --vfs-cache-max-age 24h  --vfs-cache-max-size 10G  --vfs-read-chunk-size 128M   --dir-cache-time 2h

}



##############   fügt einen alias hinzu

#    Anwendung: Danach tippst du nur noch: addalias flug 'cd ~/Documents/Flux_Logs'
#    Und zack – der Alias ist drin und aktiv. Kein nerviges Gehangel mit Anführungszeichen mehr!

addalias() {
    echo "alias $1='$2'" >> ~/.zshrc_alias
    source ~/.zshrc_alias
   # echo "✅ Alias '$1' wurde hinzugefügt und geladen, Sascha!"
}


function up {       
 if [[ "$#" < 1 ]] ; then         

    cd ..      
      else           

       CDSTR=""          
         for i in {1..$1} ; do                
         CDSTR="../$CDSTR"          
           done          
             cd $CDSTR    

    fi   
 }	


function message () {

	terminal-notifier -message "$2" -title "$1"
}

function  hg () { 

echo " $(history | grep $1 )" 
}

function open_festplattendienstprogrammAsAdmin () {  

sudo open '/System/Applications/Utilities/Disk Utility.app'

}

function ch ()  {

	if [ $1 = "dev" ];  then


	echo "wechsel nach dev macos"

	cd '/Users/sascha/Library/Mobile Documents/com~apple~CloudDocs/DEV/macos'

	pwd

fi 

} 
function mountmagazine () {

	if [ -f $HOME/mount/Magazine/check ] ; then 

		 "Magazine ist schon eingehängt";
			exit 1  
	fi

	diskutil image attach /Volumes/nvme/Sascha_Data/magazine.dmg.sparsebundle --mountPoint /Users/sascha/mount/magazine
}
